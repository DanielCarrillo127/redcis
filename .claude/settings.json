{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(cargo *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Read(.env)",
      "Read(backend/.env)",
      "Read(frontend/.env.local)",
      "Read(contracts/.contract-ids.env)"
    ]
  }
}
