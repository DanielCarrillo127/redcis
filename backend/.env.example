# =============================================================================
# redcis Backend — Environment Variables (Template)
# Copiar a .env y completar los valores
# =============================================================================

PORT=3001
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/redcis

JWT_SECRET=<random_secret_min_32_chars>
JWT_EXPIRES_IN=24h

SERVER_SIGNING_SECRET=<stellar_secret_key_S...>
HOME_DOMAIN=yourdomain.com
WEB_AUTH_DOMAIN=yourdomain.com

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

ALLOWED_ORIGINS=http://localhost:3000

NONCE_TTL_SECONDS=300

MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
