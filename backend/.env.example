# =============================================================================
# redcis Backend — Environment Variables (Template)
# Copiar a .env y completar los valores
# =============================================================================

PORT=3001
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/redcis

JWT_SECRET=<random_secret_min_32_chars>
JWT_EXPIRES_IN=24h

# stellar keys generate server-auth
# stellar keys show server-auth
SERVER_SIGNING_SECRET=<stellar_secret_key_S...>
HOME_DOMAIN=yourdomain.com
WEB_AUTH_DOMAIN=yourdomain.com

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban Contract IDs (from contracts/.contract-ids.env)
IDENTITY_REGISTRY_CONTRACT_ID=CCBLMVUJVDHK7KQKK4AFQ5NEHKPUVV6UGS5ASXOIDPVIIYZVTKTXJJ5O
ACCESS_CONTROL_CONTRACT_ID=CDT2LNOFNVLRII4NWI3CPA2Z3VW37ZWAKSBIJ6NLB7MM4NYIEQK7EY47
MEDICAL_RECORD_REGISTRY_CONTRACT_ID=CBVCGN56BQ4UESHPSXHC7O4OSOQNYQW4OUTSOD2NGL4YTOJQAYSPGIYZ

# Admin wallet (from contracts deployment)
ADMIN_WALLET=GBVSG3GQFUR4BWQCDGWJYNTE7ROSEWUSOESRMMHKNGNBA6GO7Y6ODTX5

ALLOWED_ORIGINS=http://localhost:3000

NONCE_TTL_SECONDS=300

MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
