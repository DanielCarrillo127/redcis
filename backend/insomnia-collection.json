      "name": "🔐 Auth",
      "description": "Autenticación Web3 con Freighter / Stellar"
    },
    {
      "_id": "req_auth_nonce",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "1. Obtener Nonce",
      "method": "GET",
      "url": "{{ _.base_url }}/api/auth/nonce",
      "description": "Genera el mensaje que el usuario debe firmar con Freighter.\nPaso 1 del flujo de autenticación Web3.\n\nFlujo completo:\n1. GET /nonce → obtener mensaje\n2. signMessage(message) con Freighter → obtener signature\n3. POST /verify → obtener JWT",
      "parameters": [
        {
          "name": "wallet",
          "value": "{{ _.patient_wallet }}",
          "description": "Stellar public key del usuario (G...)"
        }
      ],
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {}
    },
    {
      "_id": "req_auth_verify",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "2. Verificar Firma y Obtener JWT",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/verify",
      "description": "Verifica la firma Ed25519 del wallet y emite un JWT.\nPaso 3 del flujo de autenticación.\n\nLa `signature` es la respuesta de `signMessage()` de Freighter (base64).",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"wallet\": \"{{ _.patient_wallet }}\",\n  \"signature\": \"<BASE64_SIGNATURE_DE_FREIGHTER>\",\n  \"message\": \"Autenticación en redcis\\nWallet: {{ _.patient_wallet }}\\nNonce: <NONCE_DEL_PASO_1>\\nFecha: <FECHA_ISO>\"\n}"
      }
    },
